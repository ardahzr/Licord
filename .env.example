# =====================================================================
# Better-VC environment. Copy to `.env` and fill in. NEVER commit `.env`.
# All client-exposed vars MUST be prefixed VITE_ (bundled into the app).
# =====================================================================

# ---------------------------------------------------------------------
# 1. SUPABASE — Auth, Postgres, Realtime (WebSocket)
# ---------------------------------------------------------------------
VITE_SUPABASE_URL="https://[YOUR_SUPABASE_PROJECT_ID].supabase.co"
# Publishable key (sb_publishable_...) — client-safe, from Project Settings → API Keys
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ---------------------------------------------------------------------
# 2. CLOUDFLARE R2 — images, video, attachments (S3-compatible)
# ---------------------------------------------------------------------
# Public read base (used to render media in the UI):
VITE_R2_PUBLIC_URL="https://pub-9894ac6a16d145979e15e27120b1b4e7.r2.dev"
VITE_R2_BUCKET_NAME="better-vc"
VITE_R2_ENDPOINT="https://17468cb743850e78ba10dbeca133fb71.r2.cloudflarestorage.com"
#
# ⚠️ SECURITY (decided in Phase 3): the R2 SECRET access key must NOT be shipped
# in a VITE_ var — anything VITE_ is readable in the built client. Uploads will go
# through a Supabase Edge Function that returns a short-lived presigned URL, so the
# secret stays server-side. These two are kept here only for local prototyping and
# are git-ignored:
VITE_R2_ACCESS_KEY_ID="[R2-ACCESS-KEY]"
VITE_R2_SECRET_ACCESS_KEY="[R2-SECRET-KEY]"

# ---------------------------------------------------------------------
# 3. LIVEKIT — voice / video / screen-share (Hostinger KVM2, Phase 5)
# ---------------------------------------------------------------------
VITE_LIVEKIT_URL="wss://[YOUR_UBUNTU_DOMAIN_OR_IP]:7880"
