# =====================================================================
# Licord environment. Official builds work without this file.
# Copy to `.env` only if you are testing a self-hosted backend.
# All VITE_* vars are bundled into the client and must be treated as public.
# =====================================================================

# ---------------------------------------------------------------------
# 1. SUPABASE — optional override for self-hosted Auth/Postgres/Realtime
# ---------------------------------------------------------------------
VITE_SUPABASE_URL="https://[YOUR_SUPABASE_PROJECT_ID].supabase.co"
# Publishable key (sb_publishable_...) — client-safe, from Project Settings → API Keys
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ---------------------------------------------------------------------
# 2. CLOUDFLARE R2 — optional public media override
# ---------------------------------------------------------------------
# Uploads are handled by the `upload-url` Supabase Edge Function. R2 access keys
# live only in Supabase secrets, never in VITE_* variables.
VITE_R2_PUBLIC_URL="https://pub-[YOUR_R2_PUBLIC_ID].r2.dev"
VITE_R2_BUCKET_NAME="[YOUR_R2_BUCKET]"
VITE_R2_ENDPOINT="https://[YOUR_ACCOUNT_ID].r2.cloudflarestorage.com"

# ---------------------------------------------------------------------
# 3. LIVEKIT — optional voice/video override
# ---------------------------------------------------------------------
VITE_LIVEKIT_URL="wss://[YOUR_UBUNTU_DOMAIN_OR_IP]:7880"
