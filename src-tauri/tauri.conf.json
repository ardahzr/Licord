{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Better-VC",
  "version": "0.1.0",
  "identifier": "dev.bettervc.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Better-VC",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Network",
    "shortDescription": "Lightweight native Discord alternative for Linux",
    "longDescription": "Better-VC is a fast, native, resource-efficient communication client for Arch Linux / CachyOS. Text, media, synchronized YouTube co-watching, and voice/video — without Electron."
  }
}
