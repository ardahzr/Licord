{
  "name": "licord",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Licord — hosted Discord-inspired native chat for Arch Linux, CachyOS and Windows",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "package:linux": "tauri build --bundles deb",
    "package:linux:appimage": "NO_STRIP=1 tauri build --bundles appimage",
    "package:windows": "tauri build --bundles nsis",
    "package:windows:cross": "PATH=./scripts/bin:$PATH tauri build --bundles nsis --runner cargo-xwin --target x86_64-pc-windows-msvc"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "@livekit/components-react": "^2.9.21",
    "@livekit/components-styles": "^1.2.0",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "livekit-client": "^2.19.2",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.2",
    "@tauri-apps/cli": "^2.0.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "supabase": "2.107.0",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
